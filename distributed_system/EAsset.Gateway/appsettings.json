{
  "Jwt": {
    "Key": "EAsset_JWT_SecretKey_2026_DistributedSystem_MPPL",
    "Issuer": "EAsset.Gateway",
    "Audience": "EAsset.Services"
  },
  "ReverseProxy": {
    "Routes": {
      "asset-route": {
        "ClusterId": "asset-cluster",
        "Match": { "Path": "/api/assets/{**catch-all}" }
      },
      "categories-route": {
        "ClusterId": "asset-cluster",
        "Match": { "Path": "/api/categories/{**catch-all}" }
      },
      "scan-route": {
        "ClusterId": "asset-cluster",
        "Match": { "Path": "/api/scan/{**catch-all}" }
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "borrowing-route": {
        "ClusterId": "borrowing-cluster",
        "Match": { "Path": "/api/borrowing/{**catch-all}" }
      }
    },
    "Clusters": {
      "asset-cluster": {
        "Destinations": {
          "asset-service": { "Address": "http://localhost:5001/" }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-service": { "Address": "http://localhost:5002/" }
        }
      },
      "borrowing-cluster": {
        "Destinations": {
          "borrowing-service": { "Address": "http://localhost:5003/" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}
